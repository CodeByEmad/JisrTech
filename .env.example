# All launch configuration is environment-driven: no code edits needed.
# Set these in the hosting dashboard (Netlify/Vercel); locally in .env.local.

# Resend API key (resend.com -> API Keys). Without it, the contact form
# shows its designed WhatsApp fallback instead of sending.
RESEND_API_KEY=

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=

# Sender identity once jisrtech.sa is verified in Resend,
# e.g. "Jisr Tech <site@jisrtech.sa>". Defaults to Resend's onboarding sender.
CONTACT_FROM_EMAIL=

# Canonical origin. Defaults to https://jisrtech.sa when unset.
NEXT_PUBLIC_SITE_URL=
